{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
      "config:recommended"
    ],
    "ignorePaths": [],
    "labels": ["Skip Changelog", "dependencies"],
    "postUpdateOptions" : [
      "gomodTidy"
    ],
    "packageRules": [
      {
        "matchManagers": ["gomod"],
        "matchDepTypes": ["indirect"],
        "enabled": true
      },
      {
        "matchFileNames": ["tools/**"],
        "matchManagers": ["gomod"],
        "matchDepTypes": ["indirect"],
        "enabled": false
      },
      {
        "matchPackageNames": ["*"],
        "groupName": "All Dependencies"
      }
    ]
  }
  